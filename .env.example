APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# URL base do frontend (HTML estático). Usada em emails (links de login e
# reset de senha). Em produção aponta pro domínio real do CRM.
# Ex.: FRONTEND_URL=https://crm.alphadomusimobiliaria.com.br
FRONTEND_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =========================================================================
# Envio de emails
# =========================================================================
# Em dev, deixar MAIL_MAILER=log grava o conteúdo do email em
# storage/logs/laravel.log (útil pra inspecionar welcome/reset sem estourar
# quota SMTP).
#
# Em produção usamos SMTP do domínio (Titan / KingHost). Exemplo Titan:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.titan.email
#   MAIL_PORT=587
#   MAIL_USERNAME=noreply@alphadomusimobiliaria.com.br
#   MAIL_PASSWORD=*******
#   MAIL_ENCRYPTION=tls
#   MAIL_FROM_ADDRESS="noreply@alphadomusimobiliaria.com.br"
#   MAIL_FROM_NAME="${APP_NAME}"
#
# Obs.: emails (Welcome e ResetPassword) são enviados via queue
# (ShouldQueue). Em prod, garantir que o worker esteja rodando:
#   php artisan queue:work
# QUEUE_CONNECTION=sync também funciona (envia inline) caso não haja worker.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =========================================================================
# Hostinger API — monitoramento de VPS
# =========================================================================
# Alimenta a aba "Sistema" em Configurações (admin-only): status + uptime,
# RAM usada/disponível, disco usado/disponível, CPU média, tráfego de rede.
#
# Como gerar a API key:
#   1. Entre no hPanel (painel da Hostinger).
#   2. Menu lateral → Conta → API (ou acesse https://hpanel.hostinger.com/profile/api).
#   3. Clique em "Criar nova chave". Dê um nome descritivo (ex.: "AlphaCRM")
#      e escolha o escopo. Pra esse monitoramento basta "Read VPS" —
#      não precisa de permissão de escrita.
#   4. Copie a chave APENAS UMA VEZ (ela não é exibida de novo).
#
# Como descobrir o VPS_ID:
#   - hPanel → VPS → (abrir o servidor) → o número na URL é o ID.
#     Ex.: hpanel.hostinger.com/vps/123456  →  HOSTINGER_VPS_ID=123456
#
# Se deixar em branco, a aba Sistema mostra um aviso "integração não
# configurada" em vez de quebrar.
HOSTINGER_API_BASE=https://developers.hostinger.com
HOSTINGER_API_KEY=
HOSTINGER_VPS_ID=

# ----------------------------------------------------------------
# Quota fictícia de disco do AlphaCRM (aba Sistema + alertas)
# ----------------------------------------------------------------
# O VPS pode ser compartilhado com outros sistemas, então em vez de
# mostrar o disco total bruto do provedor a aba Sistema exibe o USED
# real (o que a Hostinger devolve) dividido por essa quota reservada.
# O numerador NÃO muda — só o denominador. O alerta de 75% passa a
# disparar em cima dessa quota (75% de 30 GB = 22.5 GB usados).
#
# ALPHACRM_DISK_QUOTA_GB: quota reservada pro CRM, em GB. Default 30.
ALPHACRM_DISK_QUOTA_GB=30

# =========================================================================
# Google Calendar / Meet (opcional)
# =========================================================================
# Habilita a integração de visitas com Google Calendar (sync bidirecional)
# e Google Meet (link gerado automático em toda visita).
#
# Pode configurar AQUI no .env, OU via UI em Configurações → Integrações
# (Settings vence se preenchido — mais conveniente porque não precisa
# de SSH cada vez que muda).
#
# Como obter:
#   1. https://console.cloud.google.com → Novo projeto
#   2. APIs & Services → Library → habilita Google Calendar API
#   3. Credentials → Create Credentials → OAuth Client ID → Web application
#   4. Cola o GOOGLE_REDIRECT_URI nas "Authorized redirect URIs"
#   5. OAuth consent screen → adicione test users (ou publique o app)
#
# Pra essa integração funcionar de fato, ainda precisa rodar:
#   composer require google/apiclient
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.seudominio.com.br/api/admin/google/callback
GOOGLE_FRONTEND_CALLBACK=https://app.seudominio.com.br/corretor.php
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo
