APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# URL base do frontend (HTML estático). Usada em emails (links de login e
# reset de senha). Em produção aponta pro domínio real do CRM.
# Ex.: FRONTEND_URL=https://crm.alphadomusimobiliaria.com.br
FRONTEND_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =========================================================================
# Envio de emails
# =========================================================================
# Em dev, deixar MAIL_MAILER=log grava o conteúdo do email em
# storage/logs/laravel.log (útil pra inspecionar welcome/reset sem estourar
# quota SMTP).
#
# Em produção usamos SMTP do domínio (Titan / KingHost). Exemplo Titan:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.titan.email
#   MAIL_PORT=587
#   MAIL_USERNAME=noreply@alphadomusimobiliaria.com.br
#   MAIL_PASSWORD=*******
#   MAIL_ENCRYPTION=tls
#   MAIL_FROM_ADDRESS="noreply@alphadomusimobiliaria.com.br"
#   MAIL_FROM_NAME="${APP_NAME}"
#
# Obs.: emails (Welcome e ResetPassword) são enviados via queue
# (ShouldQueue). Em prod, garantir que o worker esteja rodando:
#   php artisan queue:work
# QUEUE_CONNECTION=sync também funciona (envia inline) caso não haja worker.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
